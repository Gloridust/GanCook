# ── 干饭厨子 GanCook 环境变量 ──
# 全部可选。Docker 部署开箱即用，密钥会在首次启动自动生成并持久化到 data 目录。
# 本文件主要用于本地开发（cp .env.example .env.local）。

# 数据目录：SQLite 数据库与上传图片都放这里（Docker 中映射到数据卷 /data）
DATA_DIR=./data

# 会话签名密钥（留空时：Docker 自动生成；本地开发用内置默认值）
# 如需固定，生成示例： openssl rand -base64 32
# AUTH_SECRET=

# 定时任务手动触发端点的密钥（/api/cron/tick?secret=...，留空 Docker 会自动生成）
# CRON_SECRET=

# 会话 Cookie 是否强制 Secure。默认自动按请求协议判断；HTTPS 反代识别异常时可设为 1。
# COOKIE_SECURE=

# 时区（影响自动饭局的创建/截止时间判断）
TZ=Asia/Shanghai
